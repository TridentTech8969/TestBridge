@{
    ViewData["Title"] = "Test-Bridge | Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --bg: #0d0f14;
            --surface: #13161e;
            --surface2: #1a1e2a;
            --border: #252a38;
            --accent: #4f8ef7;
            --accent2: #a78bfa;
            --danger: #f05252;
            --success: #22c55e;
            --warning: #f59e0b;
            --info: #38bdf8;
            --text: #e8eaf2;
            --muted: #6b7280;
            --mono: 'DM Mono', monospace;
            --sans: 'DM Sans', sans-serif;
            --display: 'Syne', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--sans);
            min-height: 100vh;
            font-size: 14px;
        }

        /* ── TOP BAR ── */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
            height: 60px;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .logo {
            font-family: var(--display);
            font-weight: 800;
            font-size: 1.15rem;
            letter-spacing: -0.5px;
            color: var(--text);
            white-space: nowrap;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: .5rem;
            text-decoration: none;
        }
        .logo span { color: var(--accent); }
        .logo-dot {
            width: 8px; height: 8px;
            background: var(--accent);
            border-radius: 50%;
            display: inline-block;
        }

        .search-wrap {
            flex: 1;
            max-width: 420px;
            position: relative;
        }
        .search-wrap i {
            position: absolute;
            left: .85rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .95rem;
            pointer-events: none;
        }
        .search-input {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: .45rem .85rem .45rem 2.25rem;
            color: var(--text);
            font-family: var(--sans);
            font-size: .85rem;
            outline: none;
            transition: border-color .2s;
        }
        .search-input::placeholder { color: var(--muted); }
        .search-input:focus { border-color: var(--accent); }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: .5rem;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: .35rem .75rem;
            cursor: pointer;
            transition: border-color .2s;
        }
        .user-chip:hover { border-color: var(--accent); }

        .avatar {
            width: 28px; height: 28px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--display);
            font-weight: 700;
            font-size: .75rem;
            color: #fff;
            flex-shrink: 0;
        }
        .user-name { font-size: .82rem; font-weight: 500; }

        /* ── PAGE CONTENT ── */
        .page-content { padding: 1.75rem 2rem; }

        .toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
            gap: 1rem;
        }

        .sort-select {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            padding: .4rem .75rem;
            font-family: var(--sans);
            font-size: .82rem;
            outline: none;
            cursor: pointer;
        }
        .sort-select option { background: var(--surface2); }

        .btn-create {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .45rem 1rem;
            font-family: var(--display);
            font-weight: 600;
            font-size: .82rem;
            letter-spacing: .3px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: .4rem;
            transition: background .2s, transform .1s;
        }
        .btn-create:hover { background: #3a7ae8; transform: translateY(-1px); }
        .btn-create:disabled { background: var(--muted); cursor: not-allowed; transform: none; }

        /* ── TABLE ── */
        .table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

        .exec-table { width: 100%; border-collapse: collapse; }

        .exec-table thead tr {
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
        }
        .exec-table thead th {
            padding: .75rem 1rem;
            font-family: var(--display);
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: var(--muted);
            white-space: nowrap;
        }
        .exec-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .15s;
            cursor: pointer;
        }
        .exec-table tbody tr:last-child { border-bottom: none; }
        .exec-table tbody tr:hover { background: var(--surface2); }
        .exec-table td { padding: .85rem 1rem; vertical-align: middle; }

        .ticket-badge {
            font-family: var(--mono);
            font-size: .8rem;
            color: var(--accent);
            background: rgba(79,142,247,.1);
            border: 1px solid rgba(79,142,247,.25);
            border-radius: 6px;
            padding: .15rem .5rem;
            display: inline-block;
            white-space: nowrap;
        }

        .meta-row { display: flex; flex-direction: column; gap: 2px; }
        .meta-main { font-weight: 500; font-size: .85rem; }
        .meta-sub { font-size: .75rem; color: var(--muted); font-family: var(--mono); }

        .tag {
            display: inline-block;
            padding: .15rem .55rem;
            border-radius: 5px;
            font-size: .75rem;
            font-weight: 500;
            background: var(--surface2);
            border: 1px solid var(--border);
            color: var(--text);
        }

        /* Status select */
        .status-select {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            padding: .2rem .5rem;
            font-size: .78rem;
            font-family: var(--sans);
            outline: none;
            cursor: pointer;
            min-width: 120px;
        }
        .status-select option { background: var(--surface2); color: var(--text); }
        .status-select.s-not_started   { border-color: var(--muted);    color: var(--muted); }
        .status-select.s-in_progress   { border-color: var(--warning);  color: var(--warning); }
        .status-select.s-passed        { border-color: var(--success);  color: var(--success); }
        .status-select.s-failed        { border-color: var(--danger);   color: var(--danger); }
        .status-select.s-blocked       { border-color: #f97316;         color: #f97316; }
        .status-select.s-skipped       { border-color: var(--info);     color: var(--info); }
        .status-select.s-retest        { border-color: var(--accent2);  color: var(--accent2); }
        .status-select.s-cancelled     { border-color: var(--muted);    color: var(--muted); }

        .btn-delete {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--muted);
            padding: .25rem .55rem;
            font-size: .85rem;
            cursor: pointer;
            transition: border-color .2s, color .2s;
        }
        .btn-delete:hover { border-color: var(--danger); color: var(--danger); }

        /* Skeleton loader */
        .skeleton-row td { padding: .85rem 1rem; }
        .skeleton-line {
            height: 14px;
            background: linear-gradient(90deg, var(--surface2) 25%, var(--border) 50%, var(--surface2) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.4s infinite;
            border-radius: 4px;
        }
        @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--muted);
        }
        .empty-state i { font-size: 2.5rem; margin-bottom: 1rem; display: block; }
        .empty-state p { font-size: .9rem; }

        /* Toast */
        .toast-wrap {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: .5rem;
        }
        .toast-item {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: .65rem 1rem;
            font-size: .82rem;
            display: flex;
            align-items: center;
            gap: .5rem;
            min-width: 240px;
            box-shadow: 0 8px 24px rgba(0,0,0,.4);
            animation: toastIn .25s ease;
        }
        @@keyframes toastIn { from { opacity:0; transform: translateX(20px); } to { opacity:1; transform: translateX(0); } }
        .toast-item.success { border-color: var(--success); }
        .toast-item.error   { border-color: var(--danger); }
        .toast-item i.success { color: var(--success); }
        .toast-item i.error   { color: var(--danger); }

        /* ── MODAL ── */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.65);
            backdrop-filter: blur(4px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.show { display: flex; }

        .modal-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            width: 100%;
            max-width: 440px;
            padding: 1.75rem;
            box-shadow: 0 24px 60px rgba(0,0,0,.5);
            animation: slideUp .25s ease;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .modal-header-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }
        .modal-title { font-family: var(--display); font-size: 1.05rem; font-weight: 700; }
        .btn-close-modal {
            background: transparent;
            border: none;
            color: var(--muted);
            font-size: 1.1rem;
            cursor: pointer;
            line-height: 1;
        }
        .btn-close-modal:hover { color: var(--text); }

        .user-display {
            display: flex;
            align-items: center;
            gap: .6rem;
            margin-bottom: 1.25rem;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: .6rem .85rem;
        }
        .user-display span { font-size: .85rem; font-weight: 500; }

        .form-label-tb {
            display: block;
            font-size: .75rem;
            font-weight: 600;
            letter-spacing: .5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: .4rem;
        }
        .form-label-tb .req { color: var(--accent); margin-left: 2px; }

        .tb-input, .tb-select {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: .5rem .75rem;
            color: var(--text);
            font-family: var(--sans);
            font-size: .85rem;
            outline: none;
            margin-bottom: 1rem;
            transition: border-color .2s;
        }
        .tb-input::placeholder { color: var(--muted); }
        .tb-input:focus, .tb-select:focus { border-color: var(--accent); }
        .tb-input.error-field { border-color: var(--danger); }
        .tb-select option { background: var(--surface2); }

        .modal-footer-row {
            display: flex;
            justify-content: flex-end;
            gap: .75rem;
            margin-top: .5rem;
        }
        .btn-cancel {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--muted);
            padding: .5rem 1.1rem;
            font-family: var(--sans);
            font-size: .85rem;
            cursor: pointer;
            transition: border-color .2s, color .2s;
        }
        .btn-cancel:hover { border-color: var(--text); color: var(--text); }

        .btn-submit {
            background: var(--accent);
            border: none;
            border-radius: 8px;
            color: #fff;
            padding: .5rem 1.3rem;
            font-family: var(--display);
            font-weight: 600;
            font-size: .85rem;
            cursor: pointer;
            transition: background .2s, opacity .2s;
            display: flex;
            align-items: center;
            gap: .4rem;
        }
        .btn-submit:hover { background: #3a7ae8; }
        .btn-submit:disabled { opacity: .6; cursor: not-allowed; }

        /* spinner */
        .spinner {
            width: 14px; height: 14px;
            border: 2px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .6s linear infinite;
            display: none;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    </style>
</head>
<body>

    <!-- ── TOP BAR ── -->
    <header class="topbar">
        <a class="logo" href="/Execution/Dashboard">
            <span class="logo-dot"></span>
            Test<span>-Bridge</span>
        </a>
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="search-input" id="searchInput" placeholder="Search by ticket, device, status, user…" autocomplete="off" />
        </div>
        <div class="topbar-right">
            <div class="user-chip">
                <div class="avatar" id="avatarInitial">--</div>
                <span class="user-name" id="topbarUsername">Loading…</span>
                <i class="bi bi-chevron-down" style="font-size:.7rem; color:var(--muted);"></i>
            </div>
        </div>
    </header>

    <!-- ── MAIN ── -->
    <main class="page-content">

        <!-- Toolbar -->
        <div class="toolbar">
            <div class="d-flex align-items-center gap-2">
                <label style="font-size:.82rem; color:var(--muted);">Sort by:</label>
                <select class="sort-select" id="sortSelect">
                    <option value="newest">Newest First</option>
                    <option value="oldest">Oldest First</option>
                    <option value="ticket">Ticket No.</option>
                    <option value="status">Status</option>
                </select>
            </div>
            <button class="btn-create" id="btnOpenCreate">
                <i class="bi bi-plus-lg"></i>
                Create Execution
            </button>
        </div>

        <!-- Table -->
        <div class="table-card">
            <table class="exec-table" id="execTable">
                <thead>
                    <tr>
                        <th>Ticket No.</th>
                        <th>Summary</th>
                        <th>Device</th>
                        <th>Region</th>
                        <th>Exec. Type</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="execTableBody">
                    <!-- Skeleton rows on load -->
                    <tr class="skeleton-row">
                        <td><div class="skeleton-line" style="width:72px;"></div></td>
                        <td><div class="skeleton-line" style="width:180px;"></div></td>
                        <td><div class="skeleton-line" style="width:90px;"></div></td>
                        <td><div class="skeleton-line" style="width:60px;"></div></td>
                        <td><div class="skeleton-line" style="width:80px;"></div></td>
                        <td><div class="skeleton-line" style="width:100px;"></div></td>
                        <td><div class="skeleton-line" style="width:80px;"></div></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
        </div>

    </main>

    <!-- ── CREATE EXECUTION MODAL ── -->
    <div class="modal-overlay" id="createModal">
        <div class="modal-box">
            <div class="modal-header-row">
                <span class="modal-title">New Execution</span>
                <button class="btn-close-modal" id="btnCloseModal"><i class="bi bi-x-lg"></i></button>
            </div>

            <!-- Username (display only — pulled from session/page context) -->
            <div class="user-display">
                <div class="avatar" id="modalAvatarInitial">--</div>
                <span id="modalUsername">Loading…</span>
            </div>

            <label class="form-label-tb">Ticket Number <span class="req">*</span></label>
            <input type="text" class="tb-input" id="ticketNo" placeholder="e.g. PROJ-101" autocomplete="off" />

            <label class="form-label-tb">Device</label>
            <select class="tb-select" id="deviceSelect">
                <option value="">Select Device</option>
            </select>

            <label class="form-label-tb">Execution Type</label>
            <select class="tb-select" id="execTypeSelect">
                <option value="">Select Exec. Type</option>
                <option>Functional</option>
                <option>Regression</option>
                <option>Smoke</option>
                <option>Sanity</option>
                <option>Integration</option>
            </select>

            <label class="form-label-tb">Your Region</label>
            <select class="tb-select" id="regionSelect">
                <option value="">Select Region</option>
            </select>

            <div class="modal-footer-row">
                <button class="btn-cancel" id="btnCancelModal">Cancel</button>
                <button class="btn-submit" id="btnCreateExec">
                    <div class="spinner" id="createSpinner"></div>
                    <span id="createBtnLabel">Create</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Toast container -->
    <div class="toast-wrap" id="toastWrap"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>

        // ── CONFIG ─────────────────────────────────────────────────────────────
        // Current logged-in user — in production, inject from server-side session
        // e.g. @User.Identity.Name or a ViewBag value. Here we fall back gracefully.
        const CURRENT_USER = {
            username: '@(ViewBag.Username ?? "jsmith")',
            fullName: '@(ViewBag.FullName ?? "John Smith")',
            userId:   '@(ViewBag.UserId ?? "00000000-0000-0000-0000-000000000000")'
        };

        // ── STATUS HELPERS ─────────────────────────────────────────────────────
        const STATUS_CLASS_MAP = {
            'NOT_STARTED': 's-not_started',
            'IN_PROGRESS': 's-in_progress',
            'PASSED':      's-passed',
            'FAILED':      's-failed',
            'BLOCKED':     's-blocked',
            'SKIPPED':     's-skipped',
            'RETEST':      's-retest',
            'CANCELLED':   's-cancelled'
        };

        // All status options (loaded once, reused per row)
        let allStatuses = [];

        function statusSelectHtml(currentCode, executionId) {
            const cls = STATUS_CLASS_MAP[currentCode] || '';
            let opts = allStatuses.map(s =>
                `<option value="${s.statusCode}" ${s.statusCode === currentCode ? 'selected' : ''}>${s.statusLabel}</option>`
            ).join('');
            return `<select class="status-select ${cls}"
                            data-execution-id="${executionId}"
                            onclick="event.stopPropagation()"
                            onchange="onStatusChange(this)">
                        ${opts}
                    </select>`;
        }

        // ── TOAST ──────────────────────────────────────────────────────────────
        function showToast(message, type = 'success') {
            const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-x-circle-fill';
            const el = $(`<div class="toast-item ${type}">
                <i class="bi ${icon} ${type}"></i>
                <span>${message}</span>
            </div>`);
            $('#toastWrap').append(el);
            setTimeout(() => el.fadeOut(300, () => el.remove()), 3000);
        }

        // ── AVATAR HELPER ──────────────────────────────────────────────────────
        function initials(name) {
            if (!name) return '--';
            const parts = name.trim().split(' ');
            return parts.length >= 2
                ? (parts[0][0] + parts[parts.length - 1][0]).toUpperCase()
                : name.substring(0, 2).toUpperCase();
        }

        // ── BOOT USER UI ───────────────────────────────────────────────────────
        function bootUser() {
            const ini = initials(CURRENT_USER.fullName);
            $('#avatarInitial').text(ini);
            $('#topbarUsername').text(CURRENT_USER.fullName);
            $('#modalAvatarInitial').text(ini);
            $('#modalUsername').text(CURRENT_USER.fullName);
        }

        // ── LOAD STATUSES (for selects) ────────────────────────────────────────
        // We piggyback on the first GetExecutions call — statuses come embedded.
        // Alternatively fetch a dedicated endpoint; here we parse from first load.
        function extractStatuses(rows) {
            const seen = new Set();
            rows.forEach(r => {
                if (!seen.has(r.statusCode)) {
                    seen.add(r.statusCode);
                    allStatuses.push({ statusCode: r.statusCode, statusLabel: r.statusLabel, displayOrder: 0 });
                }
            });
            // Sort predictably
            const order = ['NOT_STARTED','IN_PROGRESS','PASSED','FAILED','BLOCKED','SKIPPED','RETEST','CANCELLED'];
            allStatuses.sort((a, b) => order.indexOf(a.statusCode) - order.indexOf(b.statusCode));
        }

        // ── LOAD DEVICE / REGION OPTIONS INTO MODAL ────────────────────────────
        // These come from the first execution list (embedded device/region data).
        // In production, expose a dedicated lookup endpoint; here we deduplicate.
        function populateModalSelects(rows) {
            const devices = [...new Set(rows.filter(r => r.deviceName).map(r => r.deviceName))];
            const regions = [...new Set(rows.filter(r => r.regionCode).map(r => r.regionCode))];

            // Fallback static lists if DB has no records yet
            const defaultDevices = ['Chrome Windows 11','Firefox Windows 10','Safari macOS Sonoma',
                                    'Edge Windows 11','iPhone 15 Pro iOS 17','Samsung Galaxy S24 Android',
                                    'iPad Pro iPadOS 17','API Client Postman'];
            const defaultRegions = ['US-EAST','US-WEST','EU-WEST','EU-CENT','APAC-IN','APAC-SG','APAC-AU'];

            const finalDevices = devices.length ? devices : defaultDevices;
            const finalRegions = regions.length ? regions : defaultRegions;

            const $d = $('#deviceSelect');
            finalDevices.forEach(d => $d.append(`<option value="${d}">${d}</option>`));

            const $r = $('#regionSelect');
            finalRegions.forEach(r => $r.append(`<option value="${r}">${r}</option>`));
        }

        // ── FORMAT DATE ────────────────────────────────────────────────────────
        function fmtDate(iso) {
            if (!iso) return '—';
            const d = new Date(iso);
            return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
        }

        // ── RENDER TABLE ───────────────────────────────────────────────────────
        function renderTable(rows) {
            const $body = $('#execTableBody');
            $body.empty();

            if (!rows.length) {
                $body.append(`<tr><td colspan="8">
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <p>No executions found. Create one to get started.</p>
                    </div>
                </td></tr>`);
                return;
            }

            rows.forEach(r => {
                const detailUrl = `/Execution/Details/${r.executionId}`;
                const execTypeTag = r.isRegression
                    ? `<span class="tag" style="border-color:var(--accent2);color:var(--accent2);">Regression</span>`
                    : `<span class="tag">${r.testCycle ?? 'Functional'}</span>`;

                $body.append(`
                    <tr onclick="window.location='${detailUrl}'" data-id="${r.executionId}">
                        <td><span class="ticket-badge">${r.ticketNo}</span></td>
                        <td>
                            <div class="meta-row">
                                <span class="meta-main" style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${r.ticketSummary ?? ''}">${r.ticketSummary ?? '—'}</span>
                                <span class="meta-sub">${r.ticketType ?? ''}</span>
                            </div>
                        </td>
                        <td><span class="tag">${r.deviceName ?? '—'}</span></td>
                        <td><span class="tag">${r.regionCode ?? '—'}</span></td>
                        <td>${execTypeTag}</td>
                        <td>${statusSelectHtml(r.statusCode, r.executionId)}</td>
                        <td>
                            <div class="meta-row" style="gap:4px;">
                                <span style="font-size:.78rem;font-weight:500;">${r.username}</span>
                                <span class="meta-sub">${fmtDate(r.executionDate)}</span>
                            </div>
                        </td>
                        <td>
                            <button class="btn-delete"
                                    onclick="event.stopPropagation(); confirmDelete('${r.executionId}', this)"
                                    title="Delete">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </td>
                    </tr>`);
            });
        }

        // ── LOAD EXECUTIONS ────────────────────────────────────────────────────
        let loadedOnce = false;

        function loadExecutions(search, sortBy) {
            const params = new URLSearchParams();
            if (search)  params.append('search',  search);
            if (sortBy)  params.append('sortBy',  sortBy);

            $.get(`/Execution/GetExecutions?${params.toString()}`)
                .done(res => {
                    if (!res.success) { showToast(res.message || 'Failed to load executions.', 'error'); return; }
                    const rows = res.data || [];
                    if (!loadedOnce) {
                        extractStatuses(rows);
                        populateModalSelects(rows);
                        loadedOnce = true;
                    }
                    renderTable(rows);
                })
                .fail(() => showToast('Network error loading executions.', 'error'));
        }

        // ── STATUS CHANGE (inline dropdown) ───────────────────────────────────
        function onStatusChange(selectEl) {
            const $sel = $(selectEl);
            const executionId = $sel.data('execution-id');
            const statusCode  = $sel.val();

            // Optimistic CSS update
            $sel.removeClass(Object.values(STATUS_CLASS_MAP).join(' '));
            $sel.addClass(STATUS_CLASS_MAP[statusCode] || '');

            $.ajax({
                url: '/Execution/UpdateStatus',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    ExecutionId:     executionId,
                    StatusCode:      statusCode,
                    ChangedByUserId: CURRENT_USER.userId
                })
            })
            .done(res => {
                if (!res.success) showToast(res.message || 'Status update failed.', 'error');
                else showToast('Status updated.');
            })
            .fail(() => showToast('Network error updating status.', 'error'));
        }

        // ── DELETE ─────────────────────────────────────────────────────────────
        function confirmDelete(executionId, btn) {
            if (!confirm('Delete this execution and all its data? This cannot be undone.')) return;

            const $btn = $(btn);
            $btn.html('<i class="bi bi-hourglass-split"></i>').prop('disabled', true);

            $.ajax({ url: `/Execution/DeleteExecution/${executionId}`, method: 'DELETE' })
                .done(res => {
                    if (!res.success) { showToast(res.message || 'Delete failed.', 'error'); $btn.html('<i class="bi bi-trash3"></i>').prop('disabled', false); return; }
                    const $row = $btn.closest('tr');
                    $row.fadeOut(200, () => { $row.remove(); showToast('Execution deleted.'); });
                })
                .fail(() => { showToast('Network error deleting execution.', 'error'); $btn.html('<i class="bi bi-trash3"></i>').prop('disabled', false); });
        }

        // ── MODAL OPEN / CLOSE ─────────────────────────────────────────────────
        function openModal()  { $('#createModal').addClass('show'); $('#ticketNo').val('').removeClass('error-field').focus(); }
        function closeModal() { $('#createModal').removeClass('show'); }

        $('#btnOpenCreate, #btnCloseModal, #btnCancelModal').on('click', function () {
            if ($(this).is('#btnOpenCreate')) openModal(); else closeModal();
        });
        $('#createModal').on('click', function (e) {
            if ($(e.target).is('#createModal')) closeModal();
        });
        $(document).on('keydown', function (e) {
            if (e.key === 'Escape') closeModal();
        });

        // ── CREATE EXECUTION ───────────────────────────────────────────────────
        $('#btnCreateExec').on('click', function () {
            const ticket = $('#ticketNo').val().trim();
            if (!ticket) {
                $('#ticketNo').addClass('error-field').focus();
                showToast('Ticket number is required.', 'error');
                return;
            }
            $('#ticketNo').removeClass('error-field');

            const $btn = $(this);
            $btn.prop('disabled', true);
            $('#createSpinner').show();
            $('#createBtnLabel').text('Creating…');

            const payload = {
                TicketNo:      ticket,
                Username:      CURRENT_USER.username,
                Device:        $('#deviceSelect').val()   || null,
                Region:        $('#regionSelect').val()   || null,
                ExecutionType: $('#execTypeSelect').val() || null
            };

            $.ajax({
                url: '/Execution/CreateExecution',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload)
            })
            .done(res => {
                if (!res.success) {
                    showToast(res.message || 'Failed to create execution.', 'error');
                } else {
                    showToast(`Execution created for ${ticket}.`);
                    closeModal();
                    loadExecutions($('#searchInput').val().trim(), $('#sortSelect').val());
                }
            })
            .fail(() => showToast('Network error creating execution.', 'error'))
            .always(() => {
                $btn.prop('disabled', false);
                $('#createSpinner').hide();
                $('#createBtnLabel').text('Create');
            });
        });

        // ── SEARCH (debounced) ─────────────────────────────────────────────────
        let searchTimer;
        $('#searchInput').on('input', function () {
            clearTimeout(searchTimer);
            const q = $(this).val().trim();
            searchTimer = setTimeout(() => {
                loadExecutions(q, $('#sortSelect').val());
            }, 350);
        });

        // ── SORT ───────────────────────────────────────────────────────────────
        $('#sortSelect').on('change', function () {
            loadExecutions($('#searchInput').val().trim(), $(this).val());
        });

        // ── INIT ───────────────────────────────────────────────────────────────
        $(function () {
            bootUser();
            loadExecutions('', 'newest');
        });

    </script>
</body>
</html>
